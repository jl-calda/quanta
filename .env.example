# Quanta — environment variables.
# Copy this file to `.env.local` and fill in your Supabase project values.
# `.env.local` is gitignored; never commit real keys.

# Supabase — Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin used to build OAuth / magic-link redirect targets.
# In production set this to your deployed URL, e.g. https://quanta.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth (set in the Supabase dashboard or local config via these).
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_GOOGLE_SECRET=
